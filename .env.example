# =============================================================================
# App
# =============================================================================
# Dominio raíz usado para resolver subdominios de sede (tenant).
# Ej: clubx.com  ->  bogota.clubx.com, medellin.clubx.com
NEXT_PUBLIC_ROOT_DOMAIN=localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# =============================================================================
# Supabase  ->  https://supabase.com/dashboard/project/_/settings/api
# =============================================================================
# "Project URL"
NEXT_PUBLIC_SUPABASE_URL=https://edqrlniicjuetdwzchqh.supabase.co
# "Project API keys" -> anon / public
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImVkcXJsbmlpY2p1ZXRkd3pjaHFoIiwicm9sZSI6ImFub24iLCJpYXQiOjE3ODE1NjY0MDYsImV4cCI6MjA5NzE0MjQwNn0.l0gdcQHJU28GqFxaWafR9VaeD3-oEEv-ovXSR6x4yaM
# "Project API keys" -> service_role (SECRETO — solo servidor, nunca al cliente)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImVkcXJsbmlpY2p1ZXRkd3pjaHFoIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc4MTU2NjQwNiwiZXhwIjoyMDk3MTQyNDA2fQ.l8lawDq_7OyUttiQCobsPJXrGZ0OzOfTnr20hblsX18

# =============================================================================
# Pagos
# =============================================================================
# Provider activo: "wompi" | "stripe"
PAYMENT_PROVIDER=wompi

# -----------------------------------------------------------------------------
# Wompi (Colombia)  ->  Panel: https://comercios.wompi.co
# Dónde conseguir las llaves:
#   Comercios -> Desarrolladores -> "Llaves de API".
#   Usa las llaves de "Pruebas" (pub_test_/prv_test_) en sandbox y las de
#   "Producción" (pub_prod_/prv_prod_) al salir a producción.
# Las dejamos VACÍAS hasta recibir las credenciales del cliente.
# -----------------------------------------------------------------------------
# Llave pública (pub_test_... / pub_prod_...). Se usa en el Web Checkout.
WOMPI_PUBLIC_KEY=
# Llave privada (prv_test_... / prv_prod_...). Para consultas server-to-server.
WOMPI_PRIVATE_KEY=
# "Secreto de eventos" (sección Eventos/Webhooks). Verifica la firma del webhook.
WOMPI_EVENTS_SECRET=
# "Secreto de integridad". Firma la transacción del Web Checkout.
WOMPI_INTEGRITY_SECRET=
# Entorno de Wompi: "sandbox" para pruebas, "production" para real.
WOMPI_ENVIRONMENT=sandbox

# -----------------------------------------------------------------------------
# Treli (suscripciones)  ->  Panel: https://treli.co  (Ajustes -> API)
# Gestiona los cobros recurrentes; liquida con Wompi por debajo.
# -----------------------------------------------------------------------------
TRELI_API_KEY=
TRELI_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Stripe (expansión internacional)  ->  https://dashboard.stripe.com/apikeys
# Esqueleto: sin uso aún. Llenar solo al activar PAYMENT_PROVIDER=stripe.
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# =============================================================================
# Sanity CMS  ->  https://www.sanity.io/manage
# project ID y dataset en la página del proyecto; el token en "API -> Tokens".
# =============================================================================
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2024-10-01
# Token de solo lectura para contenido en borrador / Preview.
SANITY_API_READ_TOKEN=

# =============================================================================
# Email (Resend)  ->  https://resend.com/api-keys
# El dominio remitente debe estar verificado en https://resend.com/domains
# =============================================================================
RESEND_API_KEY=
# Remitente verificado. RESEND_FROM_EMAIL tiene prioridad sobre EMAIL_FROM.
RESEND_FROM_EMAIL="Club X <no-reply@clubx.com>"
EMAIL_FROM="Club X <no-reply@clubx.com>"
# Secreto del webhook de Resend (Svix) -> https://resend.com/webhooks
RESEND_WEBHOOK_SECRET=
